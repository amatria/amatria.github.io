---
import { cv } from "@data/cv.ts";

import "@styles/global.css";
---

<!doctype html>
<html lang="es">
  <head>
    <meta charset="UTF-8" />

    <meta name="viewport" content="width=device-width, initial-scale=1.0" />

    <meta name="author" content={cv.name} />
    <meta
      name="description"
      content="Yo nunca — el juego para pasar una buena noche con tus amigxs."
    />

    <meta name="theme-color" content="#f5dce0" />

    <title>Yo nunca</title>

    <link rel="sitemap" href="/sitemap-index.xml" />
  </head>
  <body
    class="min-h-screen antialiased flex items-center justify-center p-4"
    style="font-family: 'Helvetica', 'Arial', sans-serif; background: linear-gradient(135deg, #f5dce0 9%, #ecbdc4 64%, #e4a0b7 98%); background-attachment: fixed;"
  >
    <slot />
  </body>
</html>
