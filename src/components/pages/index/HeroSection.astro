---
import { Image } from "astro:assets";

import Avatar from "@assets/images/Avatar.jpg";

import { cv } from "@data/cv.ts";

const [firstName, ...rest] = cv.name.split(" ");
const lastName = rest.join(" ");
---

<section class="py-24">
  <div class="md:hidden mb-6 fade-up delay-1">
    <Image
      src={Avatar}
      alt={cv.name}
      loading="eager"
      class="rounded-full object-cover w-20 h-20 ring-4 ring-purple-100"
    />
  </div>

  <div class="flex items-start gap-8">
    <div class="flex-1">
      <p
        class="text-xs font-medium tracking-widest uppercase text-gray-400 mb-6 fade-up delay-1"
      >
        {cv.website}
      </p>

      <h1
        class="font-serif text-6xl md:text-8xl font-normal leading-none tracking-tight text-zinc-900 mb-6 fade-up delay-2"
        style="font-family: var(--font-serif)"
      >
        {firstName}<br /><em class="text-purple-700">{lastName}</em>
      </h1>

      <p
        class="text-sm text-gray-500 font-light max-w-sm leading-relaxed mb-8 fade-up delay-3"
      >
        {cv.title}
      </p>

      <div class="flex flex-wrap gap-2 fade-up delay-4">
        <a
          href={cv.linkedin.url}
          target="_blank"
          rel="noopener"
          class="inline-flex items-center gap-1.5 text-xs font-medium text-zinc-500 px-3 py-1.5 border border-zinc-200 rounded-full transition-all duration-200 hover:border-purple-300 hover:text-purple-700 hover:bg-purple-50"
        >
          <svg
            class="w-3 h-3 opacity-60"
            viewBox="0 0 24 24"
            fill="currentColor"
          >
            <path
              d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 0 1-2.063-2.065 2.064 2.064 0 1 1 2.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"
            ></path>
          </svg>
          {cv.linkedin.label}
        </a>

        {
          cv.github.map(({ label, url }) => (
            <a
              href={url}
              target="_blank"
              rel="noopener"
              class="inline-flex items-center gap-1.5 text-xs font-medium text-zinc-500 px-3 py-1.5 border border-zinc-200 rounded-full transition-all duration-200 hover:border-purple-300 hover:text-purple-700 hover:bg-purple-50"
            >
              <svg
                class="w-3 h-3 opacity-60"
                viewBox="0 0 24 24"
                fill="currentColor"
              >
                <path d="M12 2C6.48 2 2 6.48 2 12c0 4.42 2.87 8.17 6.84 9.49.5.09.66-.22.66-.48v-1.7C6.73 19.91 6.14 18 6.14 18c-.46-1.16-1.11-1.47-1.11-1.47-.91-.62.07-.61.07-.61 1 .07 1.53 1.03 1.53 1.03.89 1.52 2.34 1.08 2.91.83.09-.65.35-1.08.63-1.33-2.22-.25-4.56-1.11-4.56-4.94 0-1.09.39-1.98 1.03-2.68-.1-.25-.45-1.27.1-2.64 0 0 .84-.27 2.75 1.02A9.56 9.56 0 0 1 12 6.8c.85 0 1.71.11 2.51.33 1.91-1.29 2.75-1.02 2.75-1.02.55 1.37.2 2.39.1 2.64.64.7 1.03 1.59 1.03 2.68 0 3.84-2.34 4.68-4.57 4.93.36.31.68.92.68 1.85v2.74c0 .27.16.58.67.48A10.01 10.01 0 0 0 22 12c0-5.52-4.48-10-10-10z" />
              </svg>
              {label}
            </a>
          ))
        }
      </div>
    </div>

    <div class="hidden md:block flex-shrink-0">
      <Image
        src={Avatar}
        alt={cv.name}
        loading="eager"
        class="rounded-full object-cover w-28 h-28 ring-4 ring-purple-100"
      />
    </div>
  </div>
</section>
