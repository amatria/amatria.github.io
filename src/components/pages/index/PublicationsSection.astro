---
import { cv } from "@data/cv.ts";
---

<section class="py-16 border-t border-gray-100">
  <p class="section-label">Publications</p>
  <div>
    {
      cv.publications.map(({ date, title, authors, venue, doi }) => (
        <div class="timeline-grid">
          <span class="timeline-date">{date}</span>
          <div>
            {doi ? (
              <a
                href={doi}
                target="_blank"
                rel="noopener"
                class="text-sm text-zinc-700 italic leading-relaxed mb-0.5 hover:text-purple-700 transition-colors duration-200 block"
              >
                {title}
              </a>
            ) : (
              <p class="text-sm text-zinc-700 italic leading-relaxed mb-0.5">
                {title}
              </p>
            )}
            <p class="text-xs text-purple-600 font-light mb-0.5">{venue}</p>
            <p class="text-xs text-gray-400 font-light">{authors}</p>
          </div>
        </div>
      ))
    }
  </div>
</section>
